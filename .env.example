# Navigator — Environment Variables
# Copy this file to navigator/backend/.env and fill in your keys.

# Required: Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Demo mode: uses scripted simulation instead of live browser-use (recommended for demos/hackathons)
# Set to false to enable real live browsing
DEMO_MODE=true
