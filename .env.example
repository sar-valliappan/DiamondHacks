# Navigator — Environment Variables
# Copy this file to navigator/backend/.env and fill in your keys.

# Required: Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
BROWSER_USE_API_KEY=your_browser_use_api_key_here
ELEVEN_LABS_API_KEY=your_eleven_labs_api_key_here

# Demo mode: uses scripted simulation instead of live browser-use
# Set to false to enable real live browsing
DEMO_MODE=true
